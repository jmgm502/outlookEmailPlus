# Flask 配置
# 必须设置！使用以下命令生成：python -c 'import secrets; print(secrets.token_hex(32))'
SECRET_KEY=your-secret-key-here

# 登录密码（默认：admin123，首次启动后会自动哈希存储）
# 生产环境建议在部署前直接设置为强密码（至少 8 位）
LOGIN_PASSWORD=admin123

# 是否允许在“系统设置”页面修改登录密码（演示站点建议设为 false）
ALLOW_LOGIN_PASSWORD_CHANGE=true

# 应用配置
PORT=5000
HOST=0.0.0.0
FLASK_ENV=production

# 是否自动启动后台调度器（定时刷新/心跳）。生产建议 true。
SCHEDULER_AUTOSTART=true

# 数据库路径
DATABASE_PATH=data/outlook_accounts.db

# GPTMail 临时邮箱配置
GPTMAIL_BASE_URL=https://mail.chatgpt.org.uk
GPTMAIL_API_KEY=gpt-test

# OAuth Token 工具（可选，不填使用默认值）
# OAUTH_TOOL_ENABLED=true
# OAUTH_CLIENT_ID=your-client-id
# OAUTH_CLIENT_SECRET=
# OAUTH_REDIRECT_URI=http://localhost:5000/token-tool/callback
# OAUTH_SCOPE=offline_access https://outlook.office.com/IMAP.AccessAsUser.All
# 如需 Graph 可改为 offline_access https://graph.microsoft.com/.default（可选扩展）
# OAUTH_TENANT=consumers

# --- 一键更新（可选；配合 docker-compose.yml 中的 Watchtower 使用） ---
# Watchtower HTTP API 地址（默认 http://watchtower:8080，docker-compose 内网互联无需改动）
# WATCHTOWER_API_URL=http://watchtower:8080

# 一键更新鉴权 Token（可留空：留空时与 docker-compose.yml 内置默认值一致，可直接工作）
# 生产环境建议设为随机强密码：python -c "import secrets; print(secrets.token_hex(32))"
# 注意：若填写此处，docker-compose.yml 中 watchtower 服务会自动同步读取同一变量
WATCHTOWER_HTTP_API_TOKEN=

# Docker API 自更新（可选，高级功能）
# ⚠️ 警告：启用后容器可通过 Docker API 控制宿主机其他容器，存在安全风险
# 需同时取消 docker-compose.yml 中 docker.sock 挂载的注释
# DOCKER_SELF_UPDATE_ALLOW=false
